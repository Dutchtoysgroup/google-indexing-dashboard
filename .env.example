# ─────────────────────────────────────────────────────────────────
# Voorbeeld-configuratie. Kopieer dit bestand naar `.env.local` en
# vul de waarden in. Op Vercel zet je dezelfde variabelen via
# Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────

# ─── Database (Neon Postgres) ─────────────────────────────────────
# Maak een gratis project aan op https://neon.tech en kopieer de
# connection string. Het Vercel/Neon Marketplace setupt dit ook
# automatisch wanneer je een Neon-database aan je project koppelt.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# ─── Branding (zichtbaar in dashboard, e-mails, PWA) ──────────────
# NEXT_PUBLIC_BRAND_NAME wordt o.a. gebruikt in de paginatitel,
# de PWA-naam en de afzender van de mailrapporten.
NEXT_PUBLIC_BRAND_NAME="Mijn Merk"
NEXT_PUBLIC_BRAND_SHORT="Merk"

# ─── Webshops (welke domeinen verschijnen op het dashboard) ───────
# JSON-array met objecten { id, name, flag, domain }.
# Het veld `id` moet exact overeenkomen met de shop_id zoals die
# door de indexing-pipeline in de database wordt gezet.
NEXT_PUBLIC_SHOPS_CONFIG='[{"id":"shop_nl","name":"Nederland","flag":"🇳🇱","domain":"voorbeeld.nl"},{"id":"shop_de","name":"Deutschland","flag":"🇩🇪","domain":"voorbeeld.de"}]'

# ─── Basis-URL van het dashboard ──────────────────────────────────
# Lokaal: http://localhost:3000
# Productie: https://jouw-project.vercel.app of een eigen domein.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ─── E-mail rapporten (optioneel) ─────────────────────────────────
# Vul GMAIL_USER en GMAIL_APP_PASSWORD in om mailrapporten te
# kunnen versturen. App Password genereren:
# https://myaccount.google.com/apppasswords (2FA moet aan staan).
GMAIL_USER=""
GMAIL_APP_PASSWORD=""
EMAIL_TO=""
# Override van de afzendernaam; standaard wordt NEXT_PUBLIC_BRAND_NAME gebruikt.
EMAIL_FROM_NAME=""

# ─── Cron beveiliging ─────────────────────────────────────────────
# Willekeurige string. Vercel Cron Jobs gebruiken deze om zichzelf
# bij /api/cron/email-scheduler te authenticeren.
CRON_SECRET=""

# ─── GitHub Actions trigger (optioneel) ───────────────────────────
# Alleen invullen als je vanuit het dashboard handmatig je
# pipeline-workflow wilt kunnen starten. Maak een fine-grained
# personal access token met Actions:write op die repo.
GITHUB_PAT=""
GITHUB_TRIGGER_REPO=""           # formaat: eigenaar/repo-naam
GITHUB_TRIGGER_WORKFLOW="daily-indexing.yml"
GITHUB_TRIGGER_REF="main"
